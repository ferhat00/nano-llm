# Copy to .env (gitignored) and fill in if needed. All values are OPTIONAL.

# Hugging Face token — only needed if the tokenizer/model repo is gated.
# The Nemotron Nano 4B model is open, so this is usually not required.
# HF_TOKEN=hf_xxx

# Tavily API key — only used if you switch web_search.provider to "tavily" in
# config.yaml. DuckDuckGo (the default) needs no key.
# TAVILY_API_KEY=tvly-xxx
